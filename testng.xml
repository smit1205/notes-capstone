<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Test Suite"
       parallel="classes"
       thread-count="3"
       verbose="1">

    <listeners>
        <listener class-name="listeners.TestListeners"/>
    </listeners>

    <test name="UI Tests">
        <classes>
            <class name="tests.LoginTest"/>
            <class name="tests.LogoutTest"/>
            <class name="tests.NotesTest"/>
        </classes>
    </test>

    <test name="E2E Tests">
        <packages>
            <package name="e2eTests"/>
        </packages>
    </test>

    <!-- API tests: no browser needed, run separately -->
    <test name="API Tests">
        <packages>
            <package name="apiTests"/>
        </packages>
    </test>


</suite>